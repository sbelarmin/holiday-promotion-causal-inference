##“I ignore all derived artifacts and environment-specific files to keep the repo reproducible. Only source code, configs, and authored analysis are tracked.”##

# Python bytecode - adds noise and merge conflicts
# generated by Python
# machine-specific
__pycache__/
*.py[cod]

# Virtual environments - can be recreated from requirements.txt
# os- and machine specific
# often large and noisy
# commit dependencies not environments
.venv/
venv/
env/

# Jupyter
# auto-generated checkpoint files
# no analytical value
# causes clutter and diff noise
.ipynb_checkpoints/
*.nbconvert.ipynb

# macOS
# Finder metadata
# accidental commits are common
# embarrassing but common mistake
.DS_Store

# Data outputs
# derived artifacts
# should be reproducible from code
# prevents repo bloat
# enforces "code over artifacts"
data/processed/
data/interim/
# keeps a small sample of raw data 
# keeps one illustrative file tracked
data/raw/*
!data/raw/sample.csv
!data/raw/.gitkeep

# Generated reports
# derived from notebooks/scripts
# frequently regenerated
# avoids merge conflicts
reports/figures/
reports/tables/

# Exception for final summaries
# keeps executive_summary.md, technical_appendix.md
# keeps authorized artifacts, not generated ones
!reports/writeup/

# Logs and temp files
# environment- and run-specific
# no analytical value
*.log
*.tmp


# Secrets
# prevents accidental credential leaks
# shows security awareness
# this is non-negotiable in professional repos
.env
*.env
credentials.json
secrets.yaml


# Test outputs
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
